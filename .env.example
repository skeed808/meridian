# Database
DATABASE_URL=postgresql://meridian:meridian@localhost:5432/meridian
REDIS_URL=redis://localhost:6379

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# AI (required for Phase 2 analysis pipeline)
OPENAI_API_KEY=

# Email alerts (Resend)
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@yourdomain.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Skip Clerk locally when keys are unset (uses seeded dev tenant)
MERIDIAN_DEV_AUTH=true
MERIDIAN_DEV_TENANT_KEY=dev:local-seed
ENCRYPTION_KEY=

# Scraping (Phase 2+)
PLAYWRIGHT_HEADLESS=true
SCRAPER_CONCURRENCY=5